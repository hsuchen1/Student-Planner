{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A student's task, such as an assignment, exam, or report.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this task."
        },
        "title": {
          "type": "string",
          "description": "The title or description of the task."
        },
        "type": {
          "type": "string",
          "enum": ["assignment", "exam", "report", "project", "other"],
          "description": "The type of the task."
        },
        "dueDate": {
          "type": "string",
          "format": "date-time",
          "description": "The due date of the task as an ISO string."
        },
        "completed": {
          "type": "boolean",
          "description": "Whether the task is completed."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the task was created."
        },
        "order": {
          "type": "number",
          "description": "The order of the task for custom sorting."
        },
        "googleEventId": {
          "type": "string",
          "description": "The ID of the Google Calendar event this task was imported from."
        },
        "reminderEnabled": {
          "type": "boolean",
          "description": "Whether a reminder notification is enabled for this task."
        }
      },
      "required": ["userId", "title", "type", "dueDate", "completed", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "A student's note or list.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this note."
        },
        "title": {
          "type": "string",
          "description": "The title of the note."
        },
        "content": {
          "type": "string",
          "description": "The content of the note."
        },
        "type": {
          "type": "string",
          "enum": ["text", "list"],
          "description": "The type of the note."
        },
        "listItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "completed": { "type": "boolean" }
            },
            "required": ["id", "text", "completed"]
          },
          "description": "The items in a list note."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the note was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the note was last updated."
        }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": {
        "$ref": "#/entities/Task"
      },
      "description": "Stores tasks for all users."
    },
    "/notes/{noteId}": {
      "schema": {
        "$ref": "#/entities/Note"
      },
      "description": "Stores notes for all users."
    }
  }
}
